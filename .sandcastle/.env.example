# Anthropic API key — required by the Claude Code agent inside the sandbox.
# Subscription-based auth via CLAUDE_CODE_OAUTH_TOKEN is tracked upstream
# in https://github.com/mattpocock/sandcastle/issues/191
ANTHROPIC_API_KEY=

# GitHub token — needed inside the sandbox so `gh` can authenticate when the
# planner prompt expands shell snippets like `gh issue view <n>`. Sandcastle's
# EnvResolver auto-fills empty values from process.env, so leaving this blank
# and exporting GH_TOKEN on the host also works (`export GH_TOKEN=$(gh auth token)`).
GH_TOKEN=

# Volumes persist between runs (warm pnpm cache). Run `pnpm clean` to wipe them.
# To switch models, edit the `claudeCode("…")` call in .sandcastle/main.ts.
